{
  "name": "idokon-course-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "supabase:link": "supabase link",
    "supabase:secrets": "supabase secrets set --env-file .env.supabase",
    "supabase:serve": "supabase functions serve --env-file .env",
    "supabase:deploy": "supabase functions deploy telegram-notify --no-verify-jwt && supabase functions deploy telegram-webhook --no-verify-jwt && supabase functions deploy healthz --no-verify-jwt",
    "supabase:webhook": "node scripts/set-telegram-webhook.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "supabase": "^2.20.12"
  }
}
